#!/bin/sh

# WIP check
remote="$1"
url="$2"
zero=$(git hash-object --stdin </dev/null | tr '[0-9a-f]' '0')

while read local_ref local_oid remote_ref remote_oid
do
    if test "$local_oid" = "$zero"
    then
        :
    else
        if test "$remote_oid" = "$zero"
        then
            range="$local_oid"
        else
            range="$remote_oid..$local_oid"
        fi

        commit=$(git rev-list -n 1 --grep '^WIP' "$range")
        if test -n "$commit"
        then
            echo >&2 "Found WIP commit in $local_ref, not pushing"
            exit 1
        fi
    fi
done

echo "================================================="
echo "🚀 Running all checks before pushing..."
echo "================================================="

# Step 1: Spotless alone (it modifies files)
./gradlew spotlessApply
GRADLE_EXIT_CODE=$?
if [ $GRADLE_EXIT_CODE -ne 0 ]; then
    echo "❌ Spotless failed to run."
    exit 1
fi
git diff --quiet || {
    echo "❌ Files were formatted. Stage and push again."
    exit 1
}

# Step 2: Everything else in one shot
./gradlew \
  compileJava compileTestFixturesJava compileTestJava compileIntegrationTestJava \
  checkstyleTestFixtures checkstyleTest checkstyleIntegrationTest \
  spotbugsMain spotbugsTest spotbugsTestFixtures \
  --continue \
  --parallel

if [ $GRADLE_EXIT_CODE -ne 0 ]; then
    echo "❌ One or more checks failed! Push aborted."
    echo "Check the output above for details."
    echo "Checkstyle report : build/reports/checkstyle/"
    echo "SpotBugs report   : build/reports/spotbugs/"
    exit 1
fi

echo "✅ All checks passed! Proceeding with push."
echo "================================================="

exit 0
